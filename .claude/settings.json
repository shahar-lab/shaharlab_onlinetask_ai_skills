{
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Write(experiment/**)",
      "Write(Plan/**)",
      "Write(manuscript-excerpt/**)",
      "Write(CLAUDE.md)",
      "Edit(experiment/**)",
      "Edit(Plan/**)",
      "Edit(manuscript-excerpt/**)",
      "Edit(CLAUDE.md)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_take_screenshot",
      "Bash(npm install)",
      "Bash(npm run build)",
      "Bash(npm run dev)",
      "Bash(npm run preview)",
      "Bash(npm run lint)",
      "Bash(npm test)",
      "Bash(npx vite build)",
      "Bash(node --version)",
      "Bash(npm --version)",
      "Bash(python -m http.server *)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git log *)",
      "Bash(git add experiment/**)",
      "Bash(git add Plan/**)",
      "Bash(git add CLAUDE.md)",
      "Bash(git add .claude/**)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(ls *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)"
    ]
  },
  "env": {
    "JSPSYCH_VERSION": "7",
    "EXPERIMENT_ROOT": "experiment",
    "PAVLOVIA_SERVER": "https://pavlovia.org"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"const f = process.env.CLAUDE_TOOL_INPUT_FILE_PATH || ''; if (/experiment[\\\\/](src[\\\\/].*\\.(js|html)|index\\.html|preview\\.html)$/.test(f)) { console.log('[Pipeline] Experiment source file edited: ' + f + '. Tzadok: check whether planning_architect_miri should update Plan/EXPERIMENT_BLUEPRINT.md and whether pavlovia_architect_maya should run a snippet check.'); }\""
          }
        ]
      }
    ]
  }
}
